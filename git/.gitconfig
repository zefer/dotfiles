[user]
  email = joe@zefer.co.uk
  name = Joe Roberts
[core]
  excludesfile = ~/.gitignore
[github]
  user = zefer
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[pull]
  ff = only
[alias]
  s = status -sb
  c = commit
  ca = commit -a
  b = branch
  p = push
  d = diff
  a = add
  l = log --graph --pretty=format:'%C(yellow)%h%Creset %an: %s - %Creset %C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
  sw = switch
  co = checkout

  pr-merged = "!f() { \
    branches=$(gh pr list --state merged --json headRefName --jq '.[].headRefName'); \
    for branch in $branches; do \
      case \"$branch\" in main|master|develop|staging|production|sandbox) continue;; esac; \
      if git show-ref --verify --quiet refs/heads/$branch; then \
        echo $branch; \
      fi; \
    done; \
  }; f"

  delete-pr-merged = "!f() { \
    branches=$(gh pr list --state merged --json headRefName --jq '.[].headRefName'); \
    for branch in $branches; do \
      case \"$branch\" in main|master|develop|staging|production|sandbox) continue;; esac; \
      if git show-ref --verify --quiet refs/heads/$branch; then \
        git branch -D $branch; \
      fi; \
    done; \
  }; f"
